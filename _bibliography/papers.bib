@article{socialprotection1,
  title={Government Scheme Overload: Take-Up and Targeting in a Multi-Scheme Context},
  author={Mitali Roy Mathur},
  preview={socialprotection1.jpg},
  presentations={Advances in Field Experiments (2026), GPRL-IPA Research Gathering (2026), CEGA Staff Meeting (2025)},
  funding={CEGA ($25,800), UC Davis Economics Department ($13,600), J-PAL Social Protection Initiative ($5,175)},
  research_question={How does the quantity and quality of government welfare schemes offered to individuals affect take-up and welfare?},
  methods={Randomized Controlled Trial in India},
  abstract={Governments in developing countries often offer a variety of social protection programs to their citizens, but take-up rates remain quite low. While researchers have studied interventions meant to improve the take-up and targeting of specific welfare schemes, little is known about how individuals navigate the entire system of welfare schemes and decide which ones to apply to. Exposure to a large quantity of welfare benefits can have countervailing effects. On the one hand, when individuals have many welfare schemes to choose from, they can make a targeted choice in applying to the benefit(s) that fit their needs the most. On the other hand, they might be overwhelmed by the sheer quantity of schemes they could apply to and not apply to any, leading them to miss out on key benefits. Therefore, studying how individuals make decisions on how many and which welfare schemes to apply to can shed light on the role that behavioral elements of choice play in a social protection setting. I will implement a randomized controlled trial that varies the number of benefits frontline workers share with informal workers in India, a country with thousands of welfare schemes. I conducted a similar pilot study with over 2,000 workers in New Delhi and found that on average, individuals went on to apply to 1 scheme upon learning about their eligibility. People who learned about one-scheme applied to 0.203 more schemes than did people who learned about multiple-schemes, translating to 498 more schemes availed. I will refine and scale this study to gather more evidence on "scheme overload" and investigate its welfare effects by analyzing how the quantity of schemes shared impacts the quantity and match-quality of schemes availed. My research highlights the importance of studying take-up in multi-scheme settings and motivates policies related to scheme convergence.},
  year={Social Protection},
  category={Social Protection},
  tags={Social Protection Policies, Take-Up, Targeting, Choice Overload},
  press={https://cega.berkeley.edu/collection/government-scheme-overload-take-up-and-targeting-in-a-multi-scheme-context/}
}
@article{migration1,
  title={Ahead with H-4 EAD: The Effects of Granting Work Authorization to High-Skilled Female Immigrants},
  author={Mitali Roy Mathur},
  preview={migration1.jpg},
  presentations={Economics of Migration Junior Workshop (2026), Junior Economics of Migration Zoom Seminar (2026)},
  funding={},
  research_question={What are the labor market, household, and selection effects of offering work authorization to the spouses of H-1B workers?},
  methods={Natural Language Processing, K-Means Clustering, Difference-in-Differences},
  abstract={Countries often host immigrants under a variety of visa categories. Immigration policy strictly regulates the quantity, eligibility requirements, and rights of immigrants in each visa group. Given norms around family unification, many immigrant visa categories include visas for dependents. Policymakers and researchers typically focus on studying the effects of immigration driven by lead migrants. Com- paratively less attention has focused on the dependents of these migrants. Understanding how policy changes impact immigrants on dependent visas plays an important role in studying the joint decisions migrants make. In this paper, I evaluate the effects of a 2015 change in immigration policy in the U.S. that allowed H-4 visa holders (spouses of high-skilled H-1B holders) access to employment authorization (EAD). I use natural language processing (NLP) and unsupervised machine learning (ML) to identify likely H-1B and H-4 visa holders in the American Community Survey. After validating my classification approach through a series of checks, I use a difference-in-differences strategy to isolate the policy’s labor market and family effects. I find that the work authorization restriction created a latent labor supply of high-skilled female immigrants that were ready to work, but were legally barred from doing so. One year after the policy removed these restrictions, the employment rate of H-4 visa holders increased by 42.2 percentage points relative to similar naturalized citizens, effectively closing the employment gap between citizens and H-4 visa holders. I also find that the H-4 EAD policy increased the fertility rate of H-4 visa holders by 6.3 percentage points relative to similar non-citizens. My results are driven by incumbent H-4 visa holders who were already in the U.S. prior to the policy change, indicating that the mechanism was not selection. Additional descriptive evidence suggests that the H-4 EAD policy did not change the composition of H-1B or H-4 workers. Overall, my research uses the example of the change in policy impacting H-4 visa holders to show how a simple machine-learning-based approach to visa classification can be used to analyze the effects of specific immigration policies. I find that small changes to the legal rights of dependents have short-term effects in realigning labor supply and family formation towards equilibrium, without altering the composition of new immigrants.},
  year={Migration},
  category={Migration},
  tags={High-skilled immigration, Joint migration, H-1B visa, H-4 visa}
}

@article{migration2,
  title={The Immigration Impact on Population, Labor Productivity, Investments and TFP in OECD Countries},
  author={Gaetano Basso, Mitali Roy Mathur, Giovanni Peri},
  preview={migration2.jpg},
  presentations={},
  funding={},
  research_question={What drives immigration across countries, and what are the macroeconomic effects of immigration in OECD countries?},
  methods={Local projections, Shift-share IV},
  abstract={OECD countries, and particularly Europe's leading economies, have experienced a significant decline in native population growth alongside large increases in net immigration. We compile a new and comprehensive dataset of net immigration rates from all origins to OECD countries and document the characteristics of these flows, establishing that most of the net immigration increase was from non-OECD countries and was significantly high-skilled, over the period 1990–2024. We show that the substantial cross-country heterogeneity in immigration dynamics is difficult to explain by push factors or network effects, while immigration policy – as captured by summary indices – account for only a small share of the observed variation. Unexpected immigration shocks and surges were relevant phenomena of these years. We then examine the relationship between immigration and growth in population and GDP per capita, focusing on labor productivity, capital investment, and total factor productivity (TFP), using local projections and several sources of identifying variation. We find that immigration from non-OECD countries has been a significant driver of GDP per worker growth, primarily through higher investment. High-skilled immigration, in particular, is associated with stronger human capital accumulation, faster TFP growth, and greater capital deepening. Positive immigration shocks and surges and more open immigration policies, are likewise associated with improved economic performance. By contrast, native population growth has either no effect or a weakly negative effect on GDP per capita and productivity growth. The estimated coefficients on immigration, while positive, are often imprecisely estimated. Still, their magnitude and direction are important and consistent with a large and growing literature documenting the positive effects of immigration – especially high-skilled immigration – on productivity, entrepreneurship, and economic growth.},
  year={Migration},
  category={Migration},
  tags={OECD Economies, Immigration, Population Change, Immigration Policies, Productivity, Investment, Employment-Population Ratio},
  paper={https://www.ecb.europa.eu/pub/pdf/sintra/ecb.forumcentbankpub2026_Peri_paper.en.pdf}
}

@article{migration3,
  title={Landscaping internal migrant vulnerabilities and labor department schemes},
  author={Mitali Roy Mathur},
  preview={migration4.jpg},
  presentations={},
  funding={},
  research_question={Which government schemes are most important to internal migrants in India?},
  methods={Qualitative interviews},
  abstract={I led a research project in collaboration with the research team at Jan Sahas's Migrants Resilience Collaborative. In this project, I built a database of different labor department welfare schemes in India. Next, I constructed a unique vulnerability index using a weighting technique to rank schemes based on vulnerabilities migrants experience tied to their demographic profiles. Finally, I designed an application in which users can enter different demographic profiles of migrants and see a ranking of types of schemes that may be most important to that migrant persona. This research contributes to the literature on optimal program design with respect to welfare targeting and lays the foundation for future research into interventions that can increase internal migrants' take-up of specific schemes.},
  year={Migration},
  category={Migration},
  tags={Internal Migration, Social Protection Programs, Vulnerability}
}

